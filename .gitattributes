# デフォルト: LF正規化
* text=auto eol=lf

# Windows固有スクリプトはCRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ソースコード
*.rs text eol=lf
*.cpp text eol=lf
*.c text eol=lf
*.h text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# バイナリ (差分・マージ無効)
*.gguf binary
*.tflite binary
*.so binary
*.dll binary
*.dylib binary
*.a binary
*.lib binary
*.exe binary
*.pdb binary

# Linguist: 生成物・ベンダーを統計から除外
Cargo.lock linguist-generated=true
native/** linguist-vendored=true
